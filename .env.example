# =============================================================
# Evoluter Engine — Environment Variables
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
#
# The Gemini API key is now stored server-side in Firebase Functions config.
# Set it once with: firebase functions:config:set gemini.api_key="YOUR_KEY"
# Get Firebase config: Firebase Console → Project Settings → General
# =============================================================

# Firebase Configuration (client-side — safe to have in VITE)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# Development
VITE_USE_EMULATORS="true"

# NOTE: VITE_GEMINI_API_KEY has been removed.
# The Gemini API key is now managed server-side only via:
#   firebase functions:config:set gemini.api_key="YOUR_KEY_HERE"
# For local emulator dev, set GEMINI_API_KEY in functions/.env
