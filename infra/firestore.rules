rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── HELPER FUNCTIONS ───────────────────────────────
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the user accessing data is the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the requester has role: "admin" on their user document
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── USER COLLECTIONS ─────────────────────────────────
    
    match /users/{userId} {
      // Allow read for authenticated users to support "Add by Email" lookup
      allow read: if isAuthenticated();
      
      // On creation, restrict what kind of role can be set (admin must be set manually in DB)
      allow create: if isOwner(userId) && (!request.resource.data.keys().hasAny(['role']) || request.resource.data.role in ['student', 'institution']);
      allow delete: if isOwner(userId) || isAdmin();

      // Users can update their own doc (except role/isVerified fields).
      // Admin can update ANY user doc (e.g., maxStudentsAllowed, role).
      allow update: if isAdmin() || (
        isOwner(userId) && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || !('role' in resource.data)) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isVerified']) || !('isVerified' in resource.data))
      ) || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enrolledBatches', 'joinedInstitutions'])
      );

      // ─── Subcollections ───

      match /stats/{document=**} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }
      
      match /syllabus/{document=**} {
        allow read, write: if isOwner(userId);
      }
      match /docs/{docId} {
        allow read, write: if isOwner(userId);
      }
      match /tests/{testId} {
        allow read, write: if isOwner(userId);
      }
      match /history/{historyId} {
        allow read, write: if isOwner(userId);
      }
      match /test_sessions/{sessionId} {
        allow read, create, delete: if isOwner(userId);
        allow update: if isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['flaggedForReview', 'flagReason', 'flaggedAt', 'tabSwitchCount']);
        
        match /events/{eventId} {
          allow read, write: if isOwner(userId);
        }
      }
      match /flashcards/{flashcardId} {
        allow read, write: if isOwner(userId);
      }
      match /saved_articles/{articleId} {
        allow read, write: if isOwner(userId);
      }
      match /api_usage/{date} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // ─── INSTITUTION COLLECTIONS ──────────────────────────

    match /institutions/{instId} {
      // Institution owner or admin can write
      allow write: if isOwner(instId) || isAdmin();
      allow read: if isAuthenticated(); 
      
      // Students sub-collection: institution manages their own student pool
      match /students/{studentId} {
        // Institution owner, the student themselves, or admin can read
        allow read: if isOwner(instId) || request.auth.uid == studentId || isAdmin();
        // Institution owner or admin can write (add/remove students)
        allow write: if isOwner(instId) || isAdmin();
      }
      
      match /tests/{testId} {
        allow read: if isAuthenticated(); // Students need to take tests
        allow write: if isOwner(instId) || isAdmin();
      }
    }

    // ─── SHARED / GLOBAL COLLECTIONS ──────────────────────

    // Leaderboards (Aggregation)
    match /leaderboards/{period} {
      allow read: if isAuthenticated();
      allow write: if false; // Only updated by server
    }

    // Cached Tests (Performance/Scalability)
    match /cached_tests/{testId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
    
    // ─── Question Bank & Tagging ───────────────────────
    match /question_bank/{questionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /tag_counters/{counterId} {
      allow read, update: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }
    
    // Contact Form
    match /contact_submissions/{docId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Content Collection (Global Configs, Banners)
    match /content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins collection (legacy, kept for backward compat but not used for auth check)
    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    
    // Server-only (Private)
    match /_test_questions/{testId} {
        allow read, write: if false;
    }

    // ─── Institution Tests ──────────────────────────────
    match /institution_tests/{testId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // Students need to increment counts
      allow delete: if isOwner(resource.data.creatorId) || isAdmin();

      // Student attempt submissions
      match /attempts/{attemptId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if false;
      }
    }

    // ─── Institution Batches ────────────────────────────
    match /institution_batches/{batchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.creatorId) || isAdmin();

      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(get(/databases/$(database)/documents/institution_batches/$(batchId)).data.creatorId) || isAdmin();
      }
    }
  }
}
