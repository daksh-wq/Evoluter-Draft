rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ─── HELPER FUNCTIONS ───────────────────────────────
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Restricted to safe image types — excludes image/svg+xml (XSS risk)
    function isImage() {
      return request.resource.contentType.matches('image/(png|jpeg|webp)');
    }

    function isPDF() {
      return request.resource.contentType.matches('application/pdf');
    }
    
    function isSizeBelow(mb) {
      return request.resource.size < mb * 1024 * 1024;
    }

    // ─── USER FILES ─────────────────────────────────────
    
    // Documents (PDFs only, Max 20MB) — owner-only, no listing
    match /users/{userId}/docs/{fileName} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create, update: if isOwner(userId) 
                   && isPDF() 
                   && isSizeBelow(20);
      allow delete: if isOwner(userId);
    }

    // Profile Pictures (Images only, Max 5MB) — any authenticated user can fetch, no listing
    // instId == user.uid verified in OnboardingView.jsx and InstitutionProfileView.jsx
    match /users/{userId}/profile/{fileName} {
      allow get: if isAuthenticated();
      allow list: if false;
      allow create, update: if isOwner(userId) 
                   && isImage()
                   && isSizeBelow(5);
      allow delete: if isOwner(userId);
    }

    // ─── INSTITUTION FILES ──────────────────────────────
    
    // Institution Logos — instId IS the user's UID (confirmed in app code), so isOwner(instId) is correct
    match /institutions/{instId}/{fileName} {
      allow get: if isAuthenticated();
      allow list: if false;
      allow create, update: if isOwner(instId)
                   && isImage()
                   && isSizeBelow(5);
      allow delete: if isOwner(instId);
    }

    // ─── DEFAULT DENY ───────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

