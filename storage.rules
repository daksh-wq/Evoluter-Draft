rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: check authentication
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check file ownership
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User document uploads — PDF only, owner-only, no listing
    match /users/{userId}/docs/{fileName} {
      allow get: if isOwner(userId);
      allow list: if false;
      // Max file size: 20MB, PDFs only
      allow create, update: if isOwner(userId)
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf');
      allow delete: if isOwner(userId);
    }

    // User profile images — any authenticated user can fetch (get only, not list)
    match /users/{userId}/profile/{fileName} {
      allow get: if isAuthenticated();
      allow list: if false;
      // Restricted to safe types — image/svg+xml excluded (XSS risk)
      allow create, update: if isOwner(userId)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
      allow delete: if isOwner(userId);
    }

    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

